# ─── AIDicted Play Store Review Agent — Environment Variables ───────────────
#
# Copy this file to .env and fill in your values.
# For GitHub Actions, add each value as a Repository Secret:
#   Settings → Secrets and variables → Actions → New repository secret
# ─────────────────────────────────────────────────────────────────────────────

# 1. Google AI (Gemini) API key
#    Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Path to your Google Service Account JSON key file
#    Steps to create:
#    a) Go to Google Cloud Console → APIs & Services → Credentials
#    b) Create a Service Account (e.g. "play-review-reader")
#    c) Download the JSON key file → save locally as service-account.json
#    d) In Google Play Console → Setup → API access → Link your Cloud project
#    e) Grant the service account "View app information and download bulk reports" permission
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# 3. Slack Incoming Webhook URL
#    Steps to create:
#    a) Go to https://api.slack.com/apps → Create New App → From Scratch
#    b) Features → Incoming Webhooks → Activate Incoming Webhooks
#    c) Click "Add New Webhook to Workspace" → choose your #reviews channel
#    d) Copy the Webhook URL below
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# 4. (Optional) Your app's package name — defaults to com.ai.aidicted
APP_PACKAGE_NAME=com.ai.aidicted
