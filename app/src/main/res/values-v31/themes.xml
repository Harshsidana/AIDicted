<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AIDicted" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/dark_background</item>
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.AIDicted.Main</item>
        <item name="android:windowSplashScreenAnimationDuration">0</item>
    </style>

    <style name="Theme.AIDicted.Main" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@color/dark_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
